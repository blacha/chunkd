{
  "name": "@chunkd/base",
  "version": "0.1.0",
  "scripts": {
    "clean": "tsc -b --clean",
    "build": "tsc -b --pretty",
    "build-watch": "tsc -b --pretty --watch",
    "version": "eslint lerna.json --fix",
    "bump": "lerna version --conventional-commits --no-push --sign-git-commit --sign-git-tag",
    "lint": "oxlint . --type-aware --fix && oxfmt . --write",
    "check": "oxlint . --type-aware && oxfmt . --check",
    "test": "lerna run test",
    "test:e2e": "cd packages/conformance && node src/index.ts"
  },
  "type": "module",
  "private": true,
  "keywords": [],
  "author": "Blayne Chard",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "lerna": "^9.0.3",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3"
  },
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "nohoist": [
      "**/@types/**"
    ]
  }
}
